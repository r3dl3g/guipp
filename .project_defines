#/bin/sh

SCRIPT_NAME=$(basename $0)
ACTION=${SCRIPT_NAME/.sh/}
PROJECT=${PWD##*/}
INSTALL_PREFIX=~/.local
BUILD_PREFIX=~/.cache/build
PARALLEL=$(nproc)
DEFINES=
TYPE=undefined
ARCHIVE=./archive
LOGDIR=.
LOGFILE=$LOGDIR/$ACTION.log
CMAKE_CMD=cmake

_exec() {
  echo Execute $@
  $@
}

_prepare() {
  _exec ${CMAKE_CMD} -S. -B $BUILD_PREFIX/$PROJECT/$TYPE -DCMAKE_BUILD_TYPE=$TYPE -DCMAKE_INSTALL_PREFIX=$INSTALL_PREFIX -DCMAKE_PREFIX_PATH=$INSTALL_PREFIX ${DEFINES} $@
}

_build() {
  _exec ${CMAKE_CMD} --build $BUILD_PREFIX/$PROJECT/$TYPE --parallel $PARALLEL $@
}

_install() {
  _exec ${CMAKE_CMD} --build $BUILD_PREFIX/$PROJECT/$TYPE --target install $@
}

_clean() {
  _exec ${CMAKE_CMD} --build $BUILD_PREFIX/$PROJECT/$TYPE --target clean $@
}

log_rename() {
  base=$ACTION$1.log
  next=$ACTION$2.log
  if [ -f $base ]; then
    mv -f $base $next
  fi
}

log_rotate() {
  mkdir -p $ARCHIVE
  for i in ${ACTION}.*.log; do
    mv $i $ARCHIVE/$i
  done
  pushd $ARCHIVE
  next=10
  for i in {9..1}; do
    log_rename .$i .$next
    next=$i
  done
  popd
  mv $LOGDIR/$ACTION.log $ARCHIVE/${ACTION}.1.log
}

do_logged() {
  command=$1
  shift

  echo -e "\n======= New $TYPE $ACTION at $(date) =======\n"

  if [ -r "$HOME/.config/project_defines" ]; then
    echo Loading user project_defines from $HOME/.config/project_defines
    . $HOME/.config/project_defines
  else
    echo No user project_defines found at $HOME/.config/project_defines
  fi

  $command $@
}

prepare() {
  TYPE=$1
  shift
  log_rotate
  do_logged _prepare $@ 2>&1 | tee -a $LOGFILE
}

build() {
  TYPE=$1
  shift
  log_rotate
  do_logged _build $@ 2>&1 | tee -a $LOGFILE
}

install() {
  TYPE=$1
  shift
  log_rotate
  do_logged _install $@ 2>&1 | tee -a $LOGFILE
}

clean() {
  TYPE=$1
  shift
  log_rotate
  do_logged _clean $@ 2>&1 | tee -a $LOGFILE
}
