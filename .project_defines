#/bin/sh

SCRIPT_NAME=$(basename $0)
ACTION=${SCRIPT_NAME/.sh/}
PROJECT=${PWD##*/}
if [ -z "${PLATFORM}" ]; then
  PLATFORM=linux
fi
PARALLEL=$(nproc)
CMAKE_CMD=cmake
TYPE=undefined
DEFINES=
LOGDIR=./logs
ARCHIVE=${LOGDIR}/archive

_exec() {
  echo Execute $@
  $@
}

_prepare() {
  _exec ${CMAKE_CMD} -S. --preset ${PLATFORM}_${TYPE} ${DEFINES} $@
}

_build() {
  _exec ${CMAKE_CMD} --build --preset ${PLATFORM}_${TYPE} --parallel $PARALLEL $@
}

_install() {
  _exec ${CMAKE_CMD} --build --preset ${PLATFORM}_${TYPE} --target install $@
}

_clean() {
  _exec ${CMAKE_CMD} --build --preset ${PLATFORM}_${TYPE} --target clean $@
}

log_rename() {
  base=$LOGFILE$1.log
  next=$LOGFILE$2.log
  if [ -e $base ]; then
    mv -f $base $next
  fi
}

log_rotate() {
  mkdir -p $LOGDIR
  mkdir -p $ARCHIVE

  pushd $ARCHIVE > /dev/null
  next=10
  for i in {9..1}; do
    log_rename .$i .$next
    next=$i
  done
  popd > /dev/null

  if [ -f ${LOGDIR}/${LOGFILE}.log ]; then
    mv ${LOGDIR}/${LOGFILE}.log $ARCHIVE/${LOGFILE}.1.log
  fi
}

init() {
  TYPE=$1
  PRESET=${PLATFORM}_${TYPE}
  LOGFILE=$ACTION-${TYPE}
  log_rotate
}

do_logged() {
  command=$1
  shift
  init $1
  shift

  echo -e "\n======= New $TYPE $ACTION for ${PROJECT} at $(date) =======\n" | tee -a $LOGDIR/$LOGFILE.log

  if [ -r "$HOME/.config/project_defines" ]; then
    echo Loading user project_defines from $HOME/.config/project_defines
    . $HOME/.config/project_defines
  #else
  #  echo No user project_defines found at $HOME/.config/project_defines
  fi

  $command $@ 2>&1 | tee -a $LOGDIR/$LOGFILE.log
}

prepare() {
  do_logged _prepare $@
}

build() {
  do_logged _build $@
}

install() {
  do_logged _install $@
}

clean() {
  do_logged _clean $@
}
